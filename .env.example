# Copy to .env and fill in. The LLM curator (src/map_event.py) reads ANTHROPIC_API_KEY.
# Get one at https://console.anthropic.com/ . The scoreboard/optimizer/backtest
# (score.py, curator.py) need no key — they only fetch prices via yfinance.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — the cheap-model bake-off lever. Set this to ladder via OpenRouter open-weight
# models (DeepSeek, Qwen, ...) instead of Opus, for ~10x lower token cost:
#   python src/map_event.py --provider openrouter --model deepseek/deepseek-chat-v3.2 ...
# Get one at https://openrouter.ai/keys .
OPENROUTER_API_KEY=sk-or-...

# Optional — look-ahead-safe web search for the OpenRouter ladder (Tavily, free tier ~1000
# credits/mo). end_date filtering restricts results to before the catalyst. Without it, the
# OpenRouter ladder reasons from priors only. Get one at https://app.tavily.com/ .
TAVILY_API_KEY=tvly-...
